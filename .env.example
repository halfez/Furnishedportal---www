# Required for the Stripe webhook (api/stripe-webhook.js).
# Set these in Vercel → Project → Settings → Environment Variables.
# Do NOT commit a real .env file with these values.

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_or_sk_test_xxx

# Stripe webhook signing secret. After you create the webhook endpoint in
# the Stripe dashboard (pointed at https://furnishedportal.com/api/stripe-webhook),
# Stripe shows a "Signing secret" starting with whsec_. Paste it here.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Sender. Domain must be verified in Resend (DNS records).
WELCOME_FROM_EMAIL="FurnishedPortal <support@furnishedportal.com>"

# Optional — BCC every welcome email to yourself for monitoring.
WELCOME_BCC_EMAIL=admin@furnishedportal.com

# Optional — map Stripe price IDs to plan labels in the welcome email.
# Find these in Stripe dashboard → Products → click a product → "API ID" of the price.
STRIPE_PRICE_HOST=price_xxx
STRIPE_PRICE_PORTFOLIO=price_xxx
STRIPE_PRICE_HOST_FOUNDING=price_xxx
STRIPE_PRICE_PORTFOLIO_FOUNDING=price_xxx
